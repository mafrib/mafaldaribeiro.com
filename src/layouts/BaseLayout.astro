---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const siteTitle = 'Mafalda Ribeiro';
const { title, description = 'Portfolio and photography by Mafalda Ribeiro.' } = Astro.props;
const pageTitle = title ? `${title} · ${siteTitle}` : siteTitle;
const nav = [
  { href: '/portfolio/', label: 'Portfolio' },
  { href: '/photography/', label: 'Photography' },
  { href: '/about/', label: 'About' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site).toString()} />
    <title>{pageTitle}</title>
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href="/" aria-label="Mafalda Ribeiro home">Mafalda Ribeiro</a>
      <nav class="site-nav" aria-label="Main navigation">
        {nav.map((item) => <a href={item.href}>{item.label}</a>)}
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <span>© {new Date().getFullYear()} Mafalda Ribeiro</span>
    </footer>
  </body>
</html>
